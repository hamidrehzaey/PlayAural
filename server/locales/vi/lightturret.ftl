game-name-lightturret = Tháp Pháo Quang Năng

lightturret-intro = Tháp Pháo Quang Năng bắt đầu với công suất { $power } và { $rounds } vòng trọn vẹn. Khai hỏa để nhận quang năng cùng số xu gấp đôi. Tháp pháo chỉ quá tải khi quang năng vượt công suất. Nâng cấp lõi tốn { $cost } xu và có thể phản tác dụng.
lightturret-intro-brief = Tháp Pháo Quang Năng: công suất { $power }, { $rounds } vòng, nâng cấp { $cost } xu.
lightturret-round-start = Vòng { $round } trên { $total } bắt đầu với { $alive } tháp pháo còn hoạt động.
lightturret-round-start-brief = Vòng { $round }/{ $total }. Còn hoạt động: { $alive }.

lightturret-shoot = Khai hỏa
lightturret-shoot-safe-label = Khai hỏa; còn { $headroom } công suất an toàn
lightturret-shoot-risk-label = Khai hỏa; nguy cơ quá tải { $risk }%
lightturret-upgrade = Nâng cấp lõi
lightturret-upgrade-label = Nâng cấp lõi; tốn { $cost } xu, bạn có { $coins }
lightturret-check-stats = Xem trạng thái tháp pháo

lightturret-you-shoot = Bạn khai hỏa, nhận { $gain } quang năng và { $coins } xu. Tháp pháo đang ở mức { $light } trên { $power } công suất, còn { $headroom } công suất an toàn và có { $total_coins } xu.
lightturret-player-shoots = { $player } khai hỏa, nhận { $gain } quang năng và { $coins } xu. Tháp pháo của họ đang ở mức { $light } trên { $power } công suất, còn { $headroom } công suất an toàn và có { $total_coins } xu.
lightturret-you-shoot-brief = Bạn khai hỏa: +{ $gain } quang năng, +{ $coins } xu. Quang năng { $light }/{ $power}; xu { $total_coins }.
lightturret-player-shoots-brief = { $player } khai hỏa: +{ $gain } quang năng, +{ $coins } xu. Quang năng { $light }/{ $power}; xu { $total_coins }.

lightturret-you-shoot-overload = Bạn khai hỏa, nhận { $gain } quang năng và { $coins } xu, đạt { $light } quang năng trên { $power } công suất. Tháp pháo vượt ngưỡng { $overload } và bạn bị loại, còn lại { $total_coins } xu.
lightturret-player-shoots-overload = { $player } khai hỏa, nhận { $gain } quang năng và { $coins } xu, đạt { $light } quang năng trên { $power } công suất. Tháp pháo vượt ngưỡng { $overload } và họ bị loại, còn lại { $total_coins } xu.
lightturret-you-shoot-overload-brief = Bạn quá tải: +{ $gain } quang năng, { $light }/{ $power}, vượt { $overload}. Bị loại.
lightturret-player-shoots-overload-brief = { $player } quá tải: +{ $gain } quang năng, { $light }/{ $power}, vượt { $overload}. Bị loại.

lightturret-you-upgrade = Bạn dùng { $cost } xu, nâng lõi thêm { $gain } công suất. Tháp pháo hiện có { $light } quang năng, { $power } công suất, còn { $headroom } công suất an toàn và { $coins } xu.
lightturret-player-upgrades = { $player } dùng { $cost } xu, nâng lõi thêm { $gain } công suất. Tháp pháo của họ hiện có { $light } quang năng, { $power } công suất, còn { $headroom } công suất an toàn và { $coins } xu.
lightturret-you-upgrade-brief = Bạn nâng cấp: +{ $gain } công suất. Quang năng { $light }/{ $power}; xu { $coins }.
lightturret-player-upgrades-brief = { $player } nâng cấp: +{ $gain } công suất. Quang năng { $light }/{ $power}; xu { $coins }.

lightturret-you-upgrade-accident = Bạn dùng { $cost } xu, nhưng lõi phản tác dụng và tăng { $gain } quang năng. Tháp pháo đang ở mức { $light } trên { $power } công suất, còn { $headroom } công suất an toàn và { $coins } xu.
lightturret-player-upgrades-accident = { $player } dùng { $cost } xu, nhưng lõi phản tác dụng và tăng { $gain } quang năng. Tháp pháo của họ đang ở mức { $light } trên { $power } công suất, còn { $headroom } công suất an toàn và { $coins } xu.
lightturret-you-upgrade-accident-brief = Nâng cấp của bạn phản tác dụng: +{ $gain } quang năng. Quang năng { $light }/{ $power}; xu { $coins }.
lightturret-player-upgrades-accident-brief = Nâng cấp của { $player } phản tác dụng: +{ $gain } quang năng. Quang năng { $light }/{ $power}; xu { $coins }.

lightturret-you-upgrade-overload = Bạn dùng { $cost } xu, nhưng lõi phản tác dụng và tăng { $gain } quang năng. Tháp pháo đạt { $light } quang năng trên { $power } công suất, vượt ngưỡng { $overload }, khiến bạn bị loại và còn { $coins } xu.
lightturret-player-upgrades-overload = { $player } dùng { $cost } xu, nhưng lõi phản tác dụng và tăng { $gain } quang năng. Tháp pháo đạt { $light } quang năng trên { $power } công suất, vượt ngưỡng { $overload }, khiến họ bị loại và còn { $coins } xu.
lightturret-you-upgrade-overload-brief = Nâng cấp quá tải: +{ $gain } quang năng, { $light }/{ $power}, vượt { $overload}. Bị loại.
lightturret-player-upgrades-overload-brief = { $player } nâng cấp quá tải: +{ $gain } quang năng, { $light }/{ $power}, vượt { $overload}. Bị loại.

lightturret-action-resolving = Hành động với tháp pháo đang được xử lý. Hãy chờ âm thanh và kết quả kết thúc.
lightturret-not-enough-coins = Bạn cần { $need } xu để nâng cấp lõi, nhưng hiện chỉ có { $have }.
lightturret-you-are-eliminated = Tháp pháo của bạn đã quá tải và bạn đã bị loại, nên không thể thực hiện thêm hành động.
lightturret-confirm-risky-shot = Khai hỏa lúc này có { $risk }% nguy cơ quá tải khi đang có { $light } quang năng trên { $power } công suất. Hãy khai hỏa lần nữa trong { $seconds } giây để xác nhận.

lightturret-status-round = Vòng { $round } trên { $total }. Tháp pháo còn hoạt động: { $alive }.
lightturret-stats-alive = { $player}: { $light } quang năng, { $power } công suất, còn { $headroom } công suất an toàn, { $coins } xu, nguy cơ quá tải lần bắn tới { $risk }%.
lightturret-stats-eliminated = { $player}: đã bị loại ở mức { $light } quang năng trên { $power } công suất.

lightturret-end-max-rounds = Đã hoàn thành đủ { $total } vòng. Tổng quang năng cuối cùng quyết định người thắng.
lightturret-end-max-rounds-brief = Hoàn thành { $total } vòng.
lightturret-end-all-eliminated = Mọi tháp pháo đều đã quá tải trong vòng { $round }. Tổng quang năng cuối cùng quyết định người thắng.
lightturret-end-all-eliminated-brief = Tất cả tháp pháo quá tải ở vòng { $round }.

lightturret-you-win = Bạn thắng với { $light } quang năng và { $power } công suất. { $survived ->
    [true] Tháp pháo của bạn vẫn hoạt động.
   *[false] Tổng quang năng của bạn vẫn dẫn đầu dù tháp pháo đã quá tải.
}
lightturret-player-wins = { $player } thắng với { $light } quang năng và { $power } công suất. { $survived ->
    [true] Tháp pháo của họ vẫn hoạt động.
   *[false] Tổng quang năng của họ vẫn dẫn đầu dù tháp pháo đã quá tải.
}
lightturret-you-win-brief = Bạn thắng: { $light } quang năng.
lightturret-player-wins-brief = { $player } thắng: { $light } quang năng.
lightturret-you-tie = Bạn đồng hạng nhất với { $players } ở mức { $light } quang năng.
lightturret-players-tie = { $players } đồng hạng nhất với { $light } quang năng.
lightturret-you-tie-brief = Bạn hòa với { $players}: { $light } quang năng.
lightturret-players-tie-brief = Đồng hạng: { $players}, { $light } quang năng.

lightturret-set-starting-power = Công suất ban đầu: { $power }
lightturret-enter-starting-power = Nhập công suất ban đầu:
lightturret-option-changed-power = Đã đặt công suất ban đầu thành { $power }.
lightturret-desc-starting-power = Công suất quá tải ban đầu của mỗi tháp pháo (mặc định 10, phạm vi 5-30). Quang năng bằng công suất vẫn an toàn; chỉ khi vượt công suất mới bị quá tải.
lightturret-set-max-rounds = Số vòng tối đa: { $rounds }
lightturret-enter-max-rounds = Nhập số vòng tối đa:
lightturret-option-changed-rounds = Đã đặt số vòng tối đa thành { $rounds }.
lightturret-desc-max-rounds = Số vòng trọn vẹn của trận đấu (mặc định 50, phạm vi 10-200). Mỗi tháp pháo còn hoạt động đều được hành động một lần trong vòng cuối.
lightturret-error-starting-power-invalid = Công suất ban đầu phải từ { $min } đến { $max }; giá trị hiện tại là { $power }.
lightturret-error-max-rounds-invalid = Số vòng tối đa phải từ { $min } đến { $max }; giá trị hiện tại là { $rounds }.

lightturret-status-survived = Còn hoạt động
lightturret-status-eliminated = Đã bị loại
lightturret-end-winner = Người thắng: { $player } với { $light } quang năng.
lightturret-end-tie = Đồng hạng nhất: { $players } với { $light } quang năng.
lightturret-line-format = { $rank }. { $player}: { $light } quang năng, { $power } công suất, { $coins } xu, { $status }
